# Variáveis que você vai preencher no Render → Environment

NODE_ENV=production
SESSION_SECRET=troque_por_uma_string_longa_e_aleatoria
APP_URL=https://wave-club.onrender.com

# Dados do banco MySQL no Railway
# Pegue em: Railway → seu banco MySQL → Connect → Available Variables
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=6543
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=railway
DB_SSL=true
